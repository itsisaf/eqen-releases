    <title>EQen 1.9.5</title>
    <pubDate>Wed, 22 Apr 2026 22:32:20 +0000</pubDate>
    <sparkle:version>EQen.15</sparkle:version>
    <sparkle:shortVersionString>1.9.5</sparkle:shortVersionString>
    <sparkle:minimumSystemVersion>15.0</sparkle:minimumSystemVersion>
    <description><![CDATA[Spectrum Analyzer redesigned with the app theme: framed in a card, accent-coloured curve with a soft gradient fill under the live trace, cleaner grid with a brighter 0 dB line, status pill with sample rate, proper typography.]]></description>
    <enclosure url="https://github.com/itsisaf/eqen-releases/releases/download/v1.9.5/EQen-1.9.5.dmg" sparkle:edSignature="862LCq7F1wbo7NypV7mdvM7boaFfjSwqifKZNmcc9CzTSfzfjNgXRl+jPLjpvvfD8SfJhUgSx+bVWQqIK0hQBg==" length="3662224" type="application/octet-stream" />
