    <item>
    <title>EQen 1.9.4</title>
    <pubDate>Wed, 22 Apr 2026 22:23:25 +0000</pubDate>
    <sparkle:version>EQen.14</sparkle:version>
    <sparkle:shortVersionString>1.9.4</sparkle:shortVersionString>
    <sparkle:minimumSystemVersion>15.0</sparkle:minimumSystemVersion>
    <description><![CDATA[Restored per-band background cards. Real fix: band strip parent card now gives the slider row the 260pt it intrinsically needs so slider columns don't extend past the card border.]]></description>
    <enclosure url="https://github.com/itsisaf/eqen-releases/releases/download/v1.9.4/EQen-1.9.4.dmg" sparkle:edSignature="SIcWPfGH52nWSNFVCpluUzA6nzT06TBjVHofIqxea4dT9IsCDKOkuisEIqmgRrlB2eufDrZPjPgbPs6HkqUdAQ==" length="3652117" type="application/octet-stream" />
