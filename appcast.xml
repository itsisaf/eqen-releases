    <item>
    <title>EQen 1.9.2</title>
    <pubDate>Wed, 22 Apr 2026 21:50:37 +0000</pubDate>
    <sparkle:version>EQen.12</sparkle:version>
    <sparkle:shortVersionString>1.9.2</sparkle:shortVersionString>
    <sparkle:minimumSystemVersion>15.0</sparkle:minimumSystemVersion>
    <description><![CDATA[Respects system appearance (dark/light) instead of forcing dark. Band strip has a fixed height and can't overflow. Whole window scrolls when content is taller than the window — no more clipped sliders on shorter screens.]]></description>
    <enclosure url="https://github.com/itsisaf/eqen-releases/releases/download/v1.9.2/EQen-1.9.2.dmg" sparkle:edSignature="I0ORmsNtIAg+nSNbkmejx26+n2TOp3utjDdofOgxtgXz1ses6dgTVcXio2Z1+ziJB5E24Et105TO7tkMlOoXAQ==" length="3654724" type="application/octet-stream" />
    </item>
    <item>
    <title>EQen 1.9.1</title>
    <pubDate>Wed, 22 Apr 2026 21:34:55 +0000</pubDate>
    <sparkle:version>EQen.11</sparkle:version>
    <sparkle:shortVersionString>1.9.1</sparkle:shortVersionString>
    <sparkle:minimumSystemVersion>15.0</sparkle:minimumSystemVersion>
    <description><![CDATA[Layout fixes: segmented picker text no longer wraps, band strip now spans full width, UI uses dark mode by default (pro audio convention), reduced top chrome spacing. Band strip is collapsed by default since the EQ curve is the primary control surface.]]></description>
    <enclosure url="https://github.com/itsisaf/eqen-releases/releases/download/v1.9.1/EQen-1.9.1.dmg" sparkle:edSignature="5b7oev54Sd0VG+kQ4kkaZoQ7MynNItWLTbd44Y2eF+hmab4uomYSvLkzF7dPgXlmk2drdFlXTuRBXO8KwNwpCg==" length="3652502" type="application/octet-stream" />
